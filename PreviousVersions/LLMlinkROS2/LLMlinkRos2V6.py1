#!/usr/bin/env python3
import rclpy
from rclpy.node import Node
from geometry_msgs.msg import Twist, Point 
from nav_msgs.msg import Odometry
from flask import Flask, request, jsonify
import threading
import requests
import logging
import time
import math

from std_srvs.srv import SetBool
from std_msgs.msg import Bool, Int8

# === 1. 初始化 Flask 应用 ===
app = Flask(__name__)
log = logging.getLogger('werkzeug')
log.setLevel(logging.ERROR)

ros_node = None 


# === 2. 定义 ROS 2 节点 ===
class RobotControlNode(Node):
    def __init__(self):
        super().__init__('robot_control_bridge')
        
        # 服务类型
        self.grab_client = self.create_client(SetBool, '/grab_service')
        # 发布类型
        self.cmd_publisher = self.create_publisher(Twist, '/cmd_vel', 10)#10 代表队列长度，适当调整以防止消息丢失或过载
        self.go_to_point_publisher = self.create_publisher(Point, '/goto_point', 10)# 发布目标点坐标，Point类型包含x,y,z三个字段
        self.record_path_publisher = self.create_publisher(Bool, '/record_path', 10)# True代表开始记录，False代表停止记录
        self.repeat_path_publisher = self.create_publisher(Int8, '/repeat_path', 10)# 0代表停止重复，1代表正向，-1代表反向
        # 订阅类型
        self.create_subscription(Bool, '/Radar', self.radar_callback, 10)
        self.create_subscription(Odometry, '/odom', self.chassis_odom_callback, 10)
        self.create_subscription(Odometry, '/chassis/odom', self.chassis_odom_callback, 10)
        self.create_subscription(str, '/Status', self.status_callback, 10)# 包括“save","repeat_start","repeat_stop","goto_point","avoid_obstacle"等状态反馈
        self.RadarDataHistory = []
        
        self.current_task = None
        self.is_moving = False
        self.last_chassis_odom_time = 0.0

        self.wave_person_3d = None  # 存储挥手目标的3D坐标

        # ===话题相关===
        self.repeat_msg = Int8()
        self.cmd_vel_msg = Twist()
        self.go_to_point_msg = Point()
        self.record_msg = Bool()

        # === 人物跟踪/跟随相关状态 ===
        self.is_tracking = False           # 是否正在跟随人物
        self.follow_target_distance = 0.8    # 目标保持距离（米）
        self.follow_linear_speed = 0.3       # 线速度 m/s
        self.follow_angular_gain = 0.8       # 角速度增益
        self.last_track_data_time = 0.0      # 最后一次收到跟踪数据的时间
        self.track_data_timeout = 2.0       # 超时（秒），超过此时间未收到数据则停止
        self.track_timeout_stopped = False   # 本轮视觉断流是否已经停车
        
        # 定时器：检查跟踪数据超时
        # self.create_timer(0.1, self.check_track_timeout)

        self.get_logger().info('llmbridge: ROS 2 桥接节点已完全启动！')
        self.get_logger().info('llmbridge: 正在 5000 端口监听大模型指令...')

        self.zT = 0.0  # 存储相机相对于底盘的Z坐标，供跟随控制使用
        self.xT = 0.0  # 存储相机相对于底盘的X坐标，供跟随控制使用
        self.yT = 0.0  # 存储相机相对于底盘的Y坐标，供跟随控制使用
        

# ============================== 处理大模型指令和反馈 ==================================
    def execute_command(self, name, flag):
        """处理来自大模型的控制指令"""
        self.current_task = name
        if flag.lower() == 'start':
            if name == 'goto_new_guest':
                self.get_logger().info('llmbridge: 👉 收到指令：开始前往新客人位置')
                self.is_moving = True
                
                # 1. 发送 True 启动记录吧台到目标点的路径
                self.record_msg.data = True
                self.record_path_publisher.publish(self.record_msg)
                
                # 2. 将解算好的 wave_person_3d 坐标发给底盘进行导航
                if self.wave_person_3d:
                    self.go_to_point_msg.x = float(self.wave_person_3d[2]+self.xT)  # 注意坐标转换，确保 xR 对应 Point.x，yR 对应 Point.y
                    self.go_to_point_msg.y = float(self.wave_person_3d[0]+self.yT)
                    self.go_to_point_msg.z = float(self.wave_person_3d[1]+self.zT)
                    self.go_to_point_publisher.publish(self.go_to_point_msg)
                return
            elif name == 'goto_known_guest':# 前往已知客人位置
                self.get_logger().info('llmbridge: 👉 收到指令：开始前往已知客人位置')
                
                self.is_moving = True
                self.repeat_msg.data = 1
                self.repeat_path_publisher.publish(self.repeat_msg)
            elif name == 'goto_bar':# 前往吧台位置
                self.get_logger().info('llmbridge: 👉 收到指令：开始前往吧台位置')
                
                self.repeat_msg.data = -1
                self.is_moving = True
                self.repeat_path_publisher.publish(self.repeat_msg)
                return
            elif name == 'grab':
                self.get_logger().info('llmbridge: 👉 收到指令：开始抓取')
                # 发送 True 启动抓取
                self.trigger_grab(True)
                return  
            elif name == 'place':
                self.get_logger().info('llmbridge: 👉 收到指令：开始放置')
                # 发送 False 启动放置（停止抓取）
                self.place_object(True)
                return
            elif name == 'track':
                # 启动人物跟随模式
                self.get_logger().info('llmbridge: 👉 收到指令：开始人物跟随')
                self.is_tracking = True
                self.is_moving = True
                self.last_track_data_time = time.time()
                self.track_timeout_stopped = False
                return  # 不发布速度，等待 /person_track 传入坐标
            # elif name == 'person_follow_stop':
            #     # 停止人物跟随模式
            #     self.get_logger().info('llmbridge: 🛑 收到指令：停止人物跟随')
            #     self.is_tracking = False
            #     self.is_moving = False
            #     self.track_timeout_stopped = False
            #     # 发送零速度停车
            #     self.cmd_publisher.publish(Twist())
            #     return
            else:
                self.get_logger().info(f'llmbridge: 👉 收到未知任务指令: {name}，默认停止')
                self.cmd_vel_msg.linear.x = 0.0
                self.cmd_vel_msg.linear.y = 0.0
                self.is_moving = False
                self.cmd_publisher.publish(self.cmd_vel_msg)

        elif flag.lower() == 'stop':
            self.get_logger().info(f'llmbridge: 🛑 收到指令：停止 {name}')
            self.is_moving = False
            self.is_tracking = False
            self.cmd_vel_msg.linear.x = 0.0
            self.cmd_vel_msg.linear.y = 0.0
            self.cmd_publisher.publish(self.cmd_vel_msg)
            
            # 如果是要求停止抓取，发送 False
            if name == 'grab' or name == 'place':
                self.trigger_grab(False)
                self.place_object(False)
                return
            
        

    def send_feedback_to_llm(self, robot_message:str):
        '''robot_message 包括 info为反馈信息'''
        url = "http://127.0.0.1:5001/ros2_feedback"
        payload = {"info": robot_message}
        try:
            requests.post(url, json=payload, timeout=2.0)
            self.get_logger().info('llmbridge: 已将异常状况/状态成功上报给大模型大脑')
        except Exception as e:
            self.get_logger().error(f'llmbridge: 无法连接到大模型大脑 : {e}')

# ============================== 处理相机点云数据反馈 ==================================
    def process_camera_point_data(self, data:Point):
        """处理来自相机点云的数据"""
        # 这里可以根据需要解析点云数据并进行相应的处理
        # 例如，提取特定区域的点云信息，或者将其转换为其他格式后发布到 ROS 话题
        self.get_logger().info('llmbridge: 收到相机点云数据，正在处理...')
        xR = data.z + self.xT  # 底盘坐标系下的X坐标（右正左负）
        yR = data.x + self.yT  # 底盘坐标系下的Y坐标（前正后负）
        zR = data.y + self.zT  # 底盘坐标系下的Z坐标（上正下负）
        self.get_logger().info(f'llmbridge: 相机点云坐标转换结果 - xR: {xR:.2f}, yR: {yR:.2f}, zR: {zR:.2f}')
        self.wave_person_3d = (xR, yR, zR)  # 更新挥手目标的3D坐标
        self.go_to_point_msg.x = xR
        self.go_to_point_msg.y = yR
        self.go_to_point_msg.z = zR


# ============================== 处理底盘里程计反馈 ==================================
    def chassis_odom_callback(self, msg):
        """通过底盘里程计判断底盘是否响应了速度指令。"""
        vx = msg.twist.twist.linear.x
        vy = msg.twist.twist.linear.y
        wz = msg.twist.twist.angular.z
        moving = abs(vx) > 0.01 or abs(vy) > 0.01 or abs(wz) > 0.01

        if self.is_moving and moving and time.time() - self.last_chassis_odom_time > 1.0:
            self.last_chassis_odom_time = time.time()
            self.get_logger().info(
                f'llmbridge: ✅ 底盘里程计反馈：正在运动 vx={vx:.3f}, vy={vy:.3f}, wz={wz:.3f}'
            )

# ============================== 处理雷达反馈 ==================================
    def radar_callback(self, msg):
        self.RadarDataHistory.append(msg.data)
        """处理来自雷达的反馈信息"""
        if msg.data:  # 假设 msg.data 为 True 表示检测到障碍物
            threading.Thread(
                target=self.send_feedback_to_llm, 
                args=("路线前方有障碍物，系统自动避障，不需要操作",)
            ).start()
            self.get_logger().warn('llmbridge: ⚠️ 雷达检测到障碍物，已触发自动避障机制。')
        elif msg.data == False and len(self.RadarDataHistory) >= 2 and self.RadarDataHistory[-2] == True:
            # 从有障碍物变为无障碍物
            threading.Thread(
                target=self.send_feedback_to_llm,
                args=("前方障碍物已清除，继续执行任务",)
            ).start()
            self.get_logger().info('llmbridge: ✅ 雷达反馈：前方安全，继续执行任务。')
        else:
            self.get_logger().info('llmbridge: 雷达反馈：当前路径安全。')

    def status_callback(self, msg):
        """处理来自底层节点的状态反馈"""
        status = msg.data
        self.get_logger().info(f'llmbridge: 收到底层状态反馈: {status}')
        if status == "save":
            self.get_logger().info('llmbridge: 已保存当前路径')
            # 任务完成，可以上报给大模型
            threading.Thread(
                target=self.send_feedback_to_llm, 
                args=("Path recording completed successfully.You can continue next action.",)
            ).start()
        elif status == "repeat_start":
            self.get_logger().info('llmbridge: 开始重复路径')
            threading.Thread(
                target=self.send_feedback_to_llm,
                args=("Starting path repetition.",)
            ).start()
        elif status == "repeat_stop":
            self.get_logger().info('llmbridge: 停止重复路径')
            threading.Thread(
                target=self.send_feedback_to_llm,
                args=("Path repetition stopped.You can continue next action.",)
            ).start()
        elif status == "goto_point":
            self.get_logger().info('llmbridge: 已到达目标点')
            threading.Thread(
                target=self.send_feedback_to_llm,
                args=("Successfully reached the target point.You can continue next action",)
            ).start()
        elif status == "avoid_obstacle":
            self.get_logger().warn('llmbridge: 已触发避障，正在绕行...')
            threading.Thread(
                target=self.send_feedback_to_llm,
                args=("Obstacle avoidance triggered, rerouting...",)
            ).start()
        else:
            self.get_logger().warn({status})

# ============================== 处理人物跟踪数据 ==================================
    def process_person_track_data(self, data):
        """处理来自人物跟踪的数据并控制底盘"""
        if not self.is_tracking:
            return
        
        self.last_track_data_time = time.time()
        self.track_timeout_stopped = False
        
        # RealSense坐标：x 正方向在右侧，z 正方向在正前方
        x = data.get('x', 0.0) 
        z = data.get('z', 0.0)
        track_id = data.get('track_id', -1)
        
        depth = abs(z)
        horizontal_offset = x
        
        # 计算角度误差：正数代表目标在右边
        angle_to_target = math.atan2(horizontal_offset, depth)
        
        msg = Twist()
        
        # --- 深度控制 (前进/后退) ---
        distance_error = depth - self.follow_target_distance
        if abs(distance_error) > 0.15:  # 扩大死区到 15cm，防止疯狂前后抖动
            # 如果太远就前进(0.3)，太近就后退(-0.15)
            msg.linear.x = self.follow_linear_speed * (1.0 if distance_error > 0 else -0.5)
        else:
            msg.linear.x = 0.0  
        
        # --- 角度控制 (转向) ---
        # ⚠️ 关键修正：ROS 中 angular.z 是逆时针为正（左转为正）。
        # 如果目标在右侧（angle_to_target > 0），我们需要右转，所以要发负的 angular.z。
        if abs(angle_to_target) > 0.08:  # 约 4.5 度的死区
            msg.angular.z = -self.follow_angular_gain * angle_to_target 
        else:
            msg.angular.z = 0.0
        
        self.cmd_publisher.publish(msg)
        
        if int(time.time()) % 3 == 0:
            self.get_logger().info(
                f'🎯 正在跟随 TrackID={track_id} | 深度={depth:.2f}m | 速度: v={msg.linear.x:.2f}, w={msg.angular.z:.2f}'
            )

    def check_track_timeout(self):
        """定时检查跟踪数据是否超时，超时则停车。"""
        if not self.is_tracking:
            return
        
        if time.time() - self.last_track_data_time > self.track_data_timeout:
            if self.track_timeout_stopped:
                return
            self.get_logger().warn('llmbridge: ⚠️ 人物跟踪数据超时，自动停车')
            self.cmd_publisher.publish(Twist())  # 停车
            self.track_timeout_stopped = True

# ============================== 抓取相关服务调用 ==================================
    def trigger_grab(self, enable=True):
        """调用抓取服务"""
        # 检查服务是否在线（等待1秒）
        if not self.grab_client.wait_for_service(timeout_sec=1.0):
            self.get_logger().error('llmbridge: 抓取服务 (/grab_service) 不在线，无法执行命令！')
            return

        req = SetBool.Request()
        req.data = enable
        
        # 异步调用服务，防止阻塞 Flask 和 ROS主线程
        future = self.grab_client.call_async(req)
        # 绑定回调函数，等底层回复后再执行
        future.add_done_callback(self.grab_response_callback)
        
        action = "启动" if enable else "停止"
        self.get_logger().info(f'📤 已发送【{action}】请求给抓取节点，等待回复...')

    def grab_response_callback(self, future):
        """处理抓取服务返回的结果"""
        try:
            response = future.result()
            if response.success:
                self.get_logger().info(f'llmbridge: 抓取节点反馈: 成功! ({response.message})')
                
                # 任务成功，可以上报给大模型
                threading.Thread(
                    target=self.send_feedback_to_llm, 
                    args=("Grab task completed successfully.You can continue next action.",)
                ).start()
            else:
                self.get_logger().warn(f'llmbridge: 抓取节点反馈: 失败! ({response.message})')
                # 任务失败，上报给大模型求助或记录
                threading.Thread(
                    target=self.send_feedback_to_llm, 
                    args=(f"Grab task failed. Reason: {response.message},try to adjust the position or check the environment and then use the tool to retry.",)
                ).start()
        except Exception as e:
            self.get_logger().error(f'llmbridge: 服务调用过程发生异常: {e}')

# ============================== 放置状态处理==================================
    def place_response_callback(self, future):
        """处理放置服务返回的结果"""
        try:
            response = future.result()
            if response.success:
                self.get_logger().info(f'llmbridge: 放置节点反馈: 成功! ({response.message})')
                # 任务成功，可以上报给大模型
                threading.Thread(
                    target=self.send_feedback_to_llm, 
                    args=("Place task completed successfully.You can continue next action.",)
                ).start()
            else:
                self.get_logger().warn(f'llmbridge: 放置节点反馈: 失败! ({response.message})')
                # 任务失败，上报给大模型求助或记录
                threading.Thread(
                    target=self.send_feedback_to_llm, 
                    args=(f"Place task failed. Reason: {response.message},try to adjust the position or check the environment and then use the tool to retry.",)
                ).start()
        except Exception as e:
            self.get_logger().error(f'llmbridge: 服务调用过程发生异常: {e}')
    
    def place_object(self, enable=True):
        """调用放置服务"""
        # 检查服务是否在线（等待1秒）
        if not self.grab_client.wait_for_service(timeout_sec=1.0):
            self.get_logger().error('llmbridge: 放置服务 (/grab_service) 不在线，无法执行命令！')
            return

        req = SetBool.Request()
        req.data = not enable  # 放置时发送 False
        
        # 异步调用服务，防止阻塞 Flask 和 ROS主线程
        future = self.grab_client.call_async(req)
        # 绑定回调函数，等底层回复后再执行
        future.add_done_callback(self.place_response_callback)
        
        action = "启动" if enable else "停止"
        self.get_logger().info(f'📤 已发送【{action}】请求给放置节点，等待回复...')


# ======================================= 定义 Flask 路由 =============================================
@app.route('/control', methods=['POST'])
def control_robot():
    data = request.json
    name = data.get('name')
    flag = data.get('flag')
    person_3d = data.get('person_3d')  # 提取随 HTTP 请求发来的 3D 坐标
    
    if ros_node and name and flag:
        # 如果收到坐标，在这里进行解算并发送给底盘
        if person_3d and isinstance(person_3d, list) and len(person_3d) == 3:
            px, py, pz = person_3d
            # 相机点云坐标转换到底盘坐标系下
            xR = pz + ros_node.xT
            yR = px + ros_node.yT
            zR = py + ros_node.zT
            ros_node.wave_person_3d = (xR, yR, zR)
            ros_node.get_logger().info(f'llmbridge: 解析并解算三维坐标 - xR: {xR:.2f}, yR: {yR:.2f}, zR: {zR:.2f}')

        ros_node.execute_command(name, flag)
        return jsonify({
            "status": "success", 
            "msg": f"指令 [{name} - {flag}] 已成功下发"
        }), 200
    else:
        return jsonify({"status": "error", "msg": "缺少必要的参数 name 或 flag"}), 400

# === 新增：人物跟踪数据接收路由 ===
@app.route('/person_track', methods=['POST'])
def receive_person_track():
    """
    接收来自 conda 环境（PersonTrackingServer）的人物跟踪数据。
    
    请求体 JSON:
    {
        "track_id": 1,
        "x": 0.15,     # 水平偏移（米），左负右正
        "y": -0.05,    # 垂直偏移（米）
        "z": 1.8,      # 深度距离（米）
        "is_tracking": true
    }
    """
    data = request.json
    if not data or not ros_node:
        return jsonify({"status": "error", "msg": "无效数据或节点未就绪"}), 400
    
    is_tracking = data.get('is_tracking', False)
    if not is_tracking:
        return jsonify({"status": "ok", "msg": "未在跟踪状态"}), 200
    
    # 交给 ROS2 节点处理
    ros_node.process_person_track_data(data)
    return jsonify({"status": "ok"}), 200

@app.route('/camera_point', methods=['POST'])
def receive_camera_point():
    """接收相机点云数据"""
    data = request.json
    if not data or not ros_node:
        return jsonify({"status": "error", "msg": "无效数据或节点未就绪"}), 400

    # 交给 ROS2 节点处理
    ros_node.process_camera_point_data(data)
    return jsonify({"status": "ok"}), 200

@app.route('/cmd_twist', methods=['POST'])
def receive_twist():
    """直接接收 Twist 格式的 JSON 并发布到底盘"""
    data = request.json
    if ros_node and data:
        msg = Twist()
        # 解析 linear
        msg.linear.x = float(data.get('linear', {}).get('x', 0.0))
        msg.linear.y = float(data.get('linear', {}).get('y', 0.0))
        msg.linear.z = float(data.get('linear', {}).get('z', 0.0))
        # 解析 angular
        msg.angular.x = float(data.get('angular', {}).get('x', 0.0))
        msg.angular.y = float(data.get('angular', {}).get('y', 0.0))
        msg.angular.z = float(data.get('angular', {}).get('z', 0.0))
        
        # 直接发布给 /cmd_vel
        ros_node.cmd_publisher.publish(msg)
        return jsonify({"status": "success"}), 200
    return jsonify({"status": "error"}), 400

def run_flask():
    app.run(host='0.0.0.0', port=5000, debug=False, use_reloader=False)

# === 4. 主程序入口 ===
def main(args=None):
    global ros_node
    rclpy.init(args=args)
    ros_node = RobotControlNode()
    
    flask_thread = threading.Thread(target=run_flask, daemon=True)
    flask_thread.start()

    try:
        rclpy.spin(ros_node)
    except KeyboardInterrupt:
        ros_node.get_logger().info('收到退出信号，正在关闭节点...')
    finally:
        if ros_node:
            ros_node.destroy_node()
        if rclpy.ok():
            rclpy.shutdown()

if __name__ == '__main__':
    main()
